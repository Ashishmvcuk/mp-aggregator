# Copy to `.env.local` in this folder (website/) for local dev — never commit `.env.local`.
# For GitHub Pages: add the SAME variable NAMES as Repository secrets so Deploy / Scraper workflows can pass them to `npm run build`.
#
# Project URL: Supabase → Project Settings → API → Project URL (must start with https://)
# Anon key:    Supabase → Project Settings → API → anon public (long JWT)

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
